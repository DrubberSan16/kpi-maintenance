# ------------------------------------------------------------------------------
# KPI MAINTENANCE - ENVIRONMENT
# ------------------------------------------------------------------------------
# Backend
PORT=3000
BASE_PATH=/kpi_maintenance

# URL publica del frontend donde se abre el modulo de alertas.
# El servicio agrega "/alertas" al final para el link del correo.
# Ejemplo: https://tu-dominio.com/app -> https://tu-dominio.com/app/alertas
PUBLIC_BASE_URL=https://tu-dominio.com/app

# ------------------------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASS=change_me
DB_NAME=kpi_justice
DB_SSL=false

# ------------------------------------------------------------------------------
# INTERNAL SERVICES
# ------------------------------------------------------------------------------
SECURITY_SERVICE_URL=http://127.0.0.1:3001/kpi_security
NOTIFICATION_SERVICE_URL=http://127.0.0.1:3002/kpi_notification

# ------------------------------------------------------------------------------
# STORAGE
# ------------------------------------------------------------------------------
WORK_ORDER_UPLOAD_DIR=/opt/kpi/kpi_maintenance/storage/work-orders
LUBRICANT_IMPORT_DIR=/opt/kpi/kpi_maintenance/storage/lubricant-imports
LUBRICANT_IMPORT_TEMPLATE_PATH=/opt/kpi/kpi_maintenance/templates/analisis-lubricante/FORMATO_CARGA_ANALISIS_LUBRICANTE.xlsx

# ------------------------------------------------------------------------------
# ALERT EMAILS
# ------------------------------------------------------------------------------
ALERT_EMAIL_FROM=tu_cuenta@gmail.com
ALERT_EMAIL_FROM_NAME=Justice KPI Alerts

# Correos fijos para recepcion de alertas
ALERT_GENERAL_MANAGER_EMAIL=gerencia.general@tu-dominio.com
ALERT_ADMINISTRATOR_EMAIL=administrador@tu-dominio.com

# ------------------------------------------------------------------------------
# SMTP
# ------------------------------------------------------------------------------
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_SECURE=false
ALERT_SMTP_USER=tu_cuenta@gmail.com
# Gmail usa smtp.gmail.com:587 con STARTTLS.
# En este backend secure=false es correcto porque Nodemailer negocia TLS por STARTTLS.
# Usa una contraseña de aplicación de Google de 16 caracteres, no tu password normal.
ALERT_SMTP_PASS=tu_app_password_de_16_caracteres
